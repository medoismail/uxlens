{
  "manifest_version": 3,
  "name": "UXLens — AI UX Audit",
  "version": "1.0.0",
  "description": "Run AI-powered UX audits on any page with one click. 10-layer diagnostic engine with Nielsen's heuristics, AI attention heatmaps, and conversion analysis.",
  "permissions": [
    "activeTab",
    "storage",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "https://www.uxlens.pro/*",
    "https://uxlens.pro/*"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.uxlens.pro/extension/*", "https://uxlens.pro/extension/*"],
      "js": ["content/auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["offscreen/offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": ["https://www.uxlens.pro/*", "https://uxlens.pro/*"]
  }
}
